<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.140" />
    <xacro:property name="base_width" value="0.160" />
    <xacro:property name="base_height" value="0.170" />
    <xacro:property name="wheel_radius" value="0.0325" />
    <xacro:property name="wheel_length" value="0.025" />

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://gati_bot_model_description/mesh/base.dae" scale="1 1 1"/>
                <!--box size="${base_length} ${base_width} ${base_height}" /-->
            </geometry>
            <origin xyz="0 0 -0.016" rpy="1.5708 0 -1.5708" />
            <material name="Yellow" />
        </visual>
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <mesh filename="package://gati_bot_model_description/mesh/wheel_right.dae" scale="0.001 0.001 0.001"/>
                    <!-- <cylinder radius="${wheel_radius}" length="${wheel_length}" /> -->
                </geometry>
                <origin xyz="0 0.075 -0.0325" rpy="0 0 0" />
                <material name="black" />
            </visual>
        </link>
    </xacro:macro>
    
    <xacro:wheel_link prefix="right" />
    <xacro:wheel_link prefix="left" />

    <!-- <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius / 2.0}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>
    </link> -->

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <!-- <origin xyz="-0.022 ${-(base_width + wheel_length) / 2.0} 0" rpy="0 0 0" /> -->
        <origin xyz="-0.0397 -0.0872 0.0289" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="-0.0397 0.0872 0.0289" rpy="3.1416 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel_link" />
        <origin xyz="${base_length / 3.0} 0 ${-wheel_radius / 2.0}" rpy="0 0 0" />
    </joint> -->

</robot>
